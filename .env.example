# Required for POC - Azure OpenAI Configuration (matches org AI team client pattern)
# Base URL only, no path — trailing slash optional (stripped automatically).
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_KEY=your-api-key-here
# Deployment name in Azure (passed as ``model=`` to the API). Often "gpt-5" if deployment matches.
AZURE_OPENAI_DEPLOYMENT=gpt-5
# API version for Azure OpenAI REST (default matches org standard)
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Optional: set 0.0–2.0 only if your deployment supports temperature; leave unset for reasoning models
# AZURE_OPENAI_TEMPERATURE=0.7

# Optional - Anthropic (fallback LLM provider)
# ANTHROPIC_API_KEY=        # Get from https://console.anthropic.com
# LLM_PROVIDER=openai      # openai | anthropic | auto (default: auto — Azure first if keys present)
# LLM_MODEL=               # optional override for Anthropic model id, or Azure deployment if AZURE_OPENAI_DEPLOYMENT unset

# Corporate proxy / TLS inspection (if you see SSL: CERTIFICATE_VERIFY_FAILED)
# Applies to both Azure OpenAI and Anthropic (shared httpx client in shared/llm.py):
# LLM_CA_BUNDLE=C:\certs\corp-root-ca.pem
# AZURE_OPENAI_CA_BUNDLE=C:\certs\corp-root-ca.pem   # optional; same effect as LLM_CA_BUNDLE
# ANTHROPIC_CA_BUNDLE=C:\certs\corp-root-ca.pem
# (Alternatively: SSL_CERT_FILE, REQUESTS_CA_BUNDLE, or CURL_CA_BUNDLE — same idea.)
# Last resort only — disables TLS verification for LLM API calls:
# LLM_SSL_VERIFY_DISABLE=true
# AZURE_OPENAI_SSL_VERIFY_DISABLE=true
# ANTHROPIC_SSL_VERIFY_DISABLE=true

# Optional: YAML path for tailored threat digests (see company_profile.example.yaml)
# COMPANY_PROFILE=company_profile.yaml
# Optional: completion token budget for threat digest LLM (reasoning models often need 8k–32k+)
# DIGEST_MAX_COMPLETION_TOKENS=16384

# Optional: Enable feed caching for development (speeds up testing, caches for 1 hour)
# FEEDS_CACHE_ENABLED=true

# Optional: overrides read by daily_digest.sh (the systemd timer wrapper — see AZURE_VM_WEBAPP.md)
# DIGEST_SCHEDULE_DAYS=1     # look-back window for the automated daily briefing
# DIGEST_SCHEDULE_PDF=0      # set to 1 to also render a PDF on every scheduled run

# PDF Export: Install weasyprint for PDF generation
# pip install weasyprint
# Then use: python -m threat_digest --pdf

# Optional for POC (tools work without these, extra enrichment only)
# Powers the OSINT Lookup tool (web workbench "OSINT Lookup" tab / `secops osint`) —
# domain/IP/hash reputation lookups. RDAP domain/IP lookups work without this key.
# Free tier: 4 lookups/minute, 500/day (the tool self-throttles to stay within this).
VIRUSTOTAL_API_KEY=       # Get from https://www.virustotal.com (free account)
GITHUB_TOKEN=             # GitHub → Settings → Developer settings
GITHUB_REPO=your-org/your-repo

# --- Add these later when connecting to production ---
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# SENTINEL_WORKSPACE_NAME=
# SENTINEL_WORKSPACE_ID=
# TEAMS_WEBHOOK_URL=